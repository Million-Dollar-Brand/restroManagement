# Database
DATABASE_URL=postgresql://postgres:password@localhost/tablemanager

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Uploads
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# App
APP_NAME=TableManager API
VERSION=1.0.0
DESCRIPTION=REST API backend for table management service
